# Pick a ROS 2 + Gazebo pairing. Both `docker compose build` and `docker compose up`
# read these variables automatically.
#
# Default: Humble + Fortress. To switch to Jazzy + Harmonic, comment the first
# block and uncomment the second.

ROS_DISTRO=humble
GZ_PKG=ignition-fortress
GZ_VERSION=fortress
GZ_CMD=ign gazebo

# ROS_DISTRO=jazzy
# GZ_PKG=gz-harmonic
# GZ_VERSION=harmonic
# GZ_CMD=gz sim

# DDS hygiene
ROS_DOMAIN_ID=42

# Match host UID/GID so files written into the mounted workspace are owned by you
USERNAME=behnam
USER_UID=1000
USER_GID=1000
