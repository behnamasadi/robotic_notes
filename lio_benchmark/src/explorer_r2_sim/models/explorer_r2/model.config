<?xml version="1.0"?>
<model>
  <name>explorer_r2</name>
  <version>1</version>
  <sdf version="1.9">model.sdf</sdf>
  <description>
    Local copy of OpenRobotics' EXPLORER_R2_SENSOR_CONFIG_2 (CMU Team Explorer
    SubT challenge rover), with an added NavSat (GPS) sensor on base_link and
    explicit topic names so ros_gz_bridge YAML stays clean.
  </description>
</model>
