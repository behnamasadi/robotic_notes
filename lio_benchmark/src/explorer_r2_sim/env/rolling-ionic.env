# ROS 2 Rolling + Gazebo Ionic (latest of latest — expect rough edges).
# Plugin filenames stay gz-sim-*-system (same as Harmonic). The
# osrf/ros:rolling-desktop-full base image must exist for ICs build; if
# not, fall back to jazzy-harmonic.
ROS_DISTRO=rolling
GZ_PKG=gz-ionic
GZ_CMD=gz sim
ROS_DOMAIN_ID=42
